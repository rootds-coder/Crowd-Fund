{
  "name": "charity-backend",
  "version": "1.0.0",
  "description": "Backend for charity donation platform",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "create-admin": "ts-node src/scripts/createAdmin.ts",
    "create-fund": "ts-node src/scripts/createActiveFund.ts",
    "create-donations": "ts-node src/scripts/createSampleDonations.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "helmet": "^8.1.0",
    "cookie-parser": "^1.4.6",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.3",
    "qrcode": "^1.5.4",
    "express-rate-limit": "^7.5.0",
    "zod": "^3.24.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/helmet": "^4.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/mongoose": "^5.11.97",
    "@types/express-rate-limit": "^1.0.0",
    "@types/zod": "^3.22.4",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 10000
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
